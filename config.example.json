{
  "server_name": "AI Performance Engineering IL",
  "server_id": "DISCORD_SERVER_ID_HERE",
  "default_time_range_days": 7,
  "cache_stale_after_hours": 24,
  "cache_ttl_minutes": 30,
  "output_limits": {
    "max_posts": 10,
    "max_snippets_per_post": 3,
    "max_total_snippets": 25,
    "max_chars_per_snippet": 500,
    "max_output_chars": 12000
  },
  "discord_exporter_path": "PATH_TO_DiscordChatExporter_CLI",
  "env_path": ".env",
  "token_env_var": "discord_token_key",
  "tool_defaults": {
    "default_context_window": {
      "since_days": 7
    },
    "refresh_window": {
      "since_days": 1
    },
    "stale_threshold_hours": 24,
    "compact": true,
    "max_messages": 25,
    "max_chars": 12000,
    "output_language": "English",
    "auto_refresh_policy": "ask",
    "safety": {
      "export_timeout_seconds": 240,
      "server_parallel": 1,
      "stop_on_forbidden": true,
      "stop_on_unauthorized": true,
      "allow_auto_bootstrap": false,
      "retry_attempts": 0
    }
  },
  "allowed_generic_aliases": [
    "general"
  ],
